      "parameters": {
        "jsCode": "// Clean and parse JSON from text fields wrapped in ```\nreturn items.map(item => {\n    let text = item.json.text || \"\";\n\n    // Remove ``` or ```json code block wrappers\n    text = text.replace(/^```(json)?\\s*/, \"\").replace(/```$/, \"\").trim();\n\n    // Parse JSON\n    let parsed = {};\n    try {\n        parsed = JSON.parse(text);\n    } catch (err) {\n        console.error(\"JSON parse error:\", err);\n        parsed = null;\n    }\n\n    // Optional: Ensure reference IDs exist in code node\n    if (parsed && parsed.action_items) {\n        const referenceRegex = /\\b[A-Z]{3}-\\d{3}-DCN-\\d{3}\\b/;\n        parsed.action_items = parsed.action_items.map(a => {\n            const match = a.description.match(referenceRegex) || a.reference?.match(referenceRegex);\n            a.code = { reference_id: match ? match[0] : null };\n            return a;\n        });\n    }\n\n    return { json: parsed };\n});"
      },
