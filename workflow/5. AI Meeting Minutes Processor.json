  "name": "5. AI Meeting Minutes Processor",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const meeting = $input.first().json;\nconst content = $input.first().json[\"Meeting notes\"];\n\nif (content.length < 10) {\n  return {json: {skip: true, reason: 'Content too short'}};\n}\n\nreturn {\n  json: {\n    meetingId: meeting.id,\n    meetingUrl: meeting.url,\n    \"subject\":$input.first().json.Agenda,\n    \"contact\":$input.first().json[\"Internal Lead Email\"],\n    \"Content\": $input.first().json[\"Meeting notes\"],\n    \"projectId\": $input.first().json[\"Meeting Title\"],\n    skip: false\n  }\n};"
      },
      "id": "5f5c084c-7c7f-4910-b9c2-fe1ea2311227",
