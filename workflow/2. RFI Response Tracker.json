{
  "name": "2. RFI Response Tracker",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const rfi = $input.first().json;\nconst props = rfi.properties;\n\nconst reference = $input.first().json.Reference;\nconst subject = $input.first().json.Subject;\nconst receiveDate = $input.first().json['Last edited time'].split('T')[0];\nconst requiredByDate =\n  $input.first().json[' Required By Date']?.start\n    ? $input.first().json[' Required By Date'].start.split('T')[0]\n    : new Date(Date.now() + 5 * 24 * 60 * 60 * 1000)\n        .toISOString()\n        .split('T')[0];\nconst projectId = reference.split('-')[0]\n\nif (!projectId) {\n  return { json: { error: 'No project linked', skip: true } };\n}\n\nconst responseDueDate = requiredByDate || addBusinessDays(receiveDate, 5);\n\nfunction addBusinessDays(startDate, days) {\n  let current = new Date(startDate);\n  let added = 0;\n  while (added < days) {\n    current.setDate(current.getDate() + 1);\n    if (current.getDay() !== 0 && current.getDay() !== 6) added++;\n  }\n  return current.toISOString().split('T')[0];\n}\n\nreturn {\n  json: {\n    rfiId: rfi.id,\n    rfiUrl: rfi.url,\n    reference,\n    subject,\n    receiveDate,\n    responseDueDate,\n    projectId,\n    skip: false\n  }\n};"
      },
      "id": "499cd289-bf84-4a7f-a870-13a3f1903a0a",
      "name": "Extract RFI Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        160,
        -16
      ]
    },
    {
      "parameters": {
        "jsCode": "const project = $input.first().json;\n\n\nconst internalLeadEmail = $input.first().json.property_internal_lead;\nconst internalLeadName = $input.first().json.property_internal_lead_email;\nconst projectName = $input.first().json.name;\n\nconst rfiData = $('Extract RFI Data').first().json;\n\nreturn {\n  json: {\n    ...rfiData,\n    projectName,\n    assignedEmail:internalLeadEmail,\n    assignedName: internalLeadName || 'Project Team'\n  }\n};"
      },
      "id": "ad4bbb61-0c96-4bbb-b769-4a2c5f25ae42",
      "name": "Determine Assignment",
