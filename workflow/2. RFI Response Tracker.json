      "position": [
        16,
        384
      ]
    },
    {
      "parameters": {
        "jsCode": "const pages = $input.all();\nconst today = new Date();\ntoday.setHours(0, 0, 0, 0);\n\nconst results = [];\n\nfor (const item of pages) {\n  const rfi = item.json;\n\n  const requiredBy = rfi.property_required_by_date?.start;\n  if (!requiredBy) continue;\n\n  const dueDate = new Date(requiredBy);\n  const daysUntilDue = $input.first().json.property_days_until_due\n\n  if (daysUntilDue === 1 || daysUntilDue <= 0) {\n    results.push({\n      json: {\n        rfiId: rfi.id,\n        rfiUrl: rfi.url,\n        reference: rfi.property_reference,\n        subject: rfi.property_subject,\n        dueDate: requiredBy,\n        daysUntilDue,\n        isOverdue: daysUntilDue < 0,\n        status: rfi.property_status,\n        contractorName: rfi.property_contracter_name,\n        contractorEmail: rfi.property_email_contractor\n      }\n    });\n  }\n}\n\nreturn results.length > 0 ? results: [{ json: { skip: true } }];"
      },
