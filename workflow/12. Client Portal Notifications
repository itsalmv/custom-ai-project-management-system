      "parameters": {
        "jsCode": "const data = $('Aggregate Data').first().json;\nconst contact = $input.first().json;\n\nconst contactEmail = $input.first().json.recipientId;\nconst contactName = $input.first().json.resipientName;\n\n// Generate acknowledgment token\nconst ackToken = Buffer.from(\n  JSON.stringify({\n    recordId: data.recordId,\n    recipientId: data.recipientId,\n    timestamp: Date.now()\n  })\n).toString('base64');\n\nconst ackUrl = \"https://n8n.al-dar.com/webhook-test/acknowledge?token=\"+ackToken;\n\n// Generate email based on notification type\nlet emailSubject, emailBody;\n\nswitch (data.notificationType) {\n  case 'vo_issued':\n    emailSubject = `Variation Order Issued: ${data.reference}`;\n    emailBody = `\n      <h2>Variation Order Issued</h2>\n      <p>A new Variation Order has been issued for your review and acknowledgment.</p>\n      <div style=\"background: #dbeafe; padding: 20px; border-left: 4px solid #2563eb; margin: 20px 0;\">\n        <h3>${data.reference}</h3>\n        <p><strong>Project:</strong> ${data.projectCode} - ${data.projectName}</p>\n        <p><strong>Subject:</strong> ${data.subject}</p>\n        <p><strong>Issue Date:</strong> ${data.issueDate || 'Today'}</p>\n      </div>\n      <div style=\"background: #fef3c7; padding: 15px; border-left: 4px solid #f59e0b; margin: 20px 0;\">\n        <strong>⚠️ Action Required</strong><br>\n        Please acknowledge receipt of this Variation Order within 7 days.\n      </div>\n      <p style=\"text-align: center; margin: 30px 0;\">\n        <a href=\"${ackUrl}\" style=\"display: inline-block; padding: 12px 24px; background: #2563eb; color: white; text-decoration: none; border-radius: 6px;\">Acknowledge Receipt</a>\n      </p>\n    `;\n    break;\n    \n  case 'decision_published':\n    emailSubject = `Decision Recorded: ${data.reference}`;\n    emailBody = `\n      <h2>Client Decision Recorded</h2>\n      <p>Your decision has been recorded in our project management system.</p>\n      <div style=\"background: #dbeafe; padding: 20px; border-left: 4px solid #2563eb; margin: 20px 0;\">\n        <h3>${data.reference}</h3>\n        <p><strong>Project:</strong> ${data.projectCode} - ${data.projectName}</p>\n        <p><strong>Decision:</strong> ${data.subject}</p>\n        <p><strong>Date:</strong> ${data.issueDate || 'Today'}</p>\n      </div>\n      <h3>Details:</h3>\n      <p>${data.body.substring(0, 300)}...</p>\n      <p style=\"text-align: center; margin: 30px 0;\">\n        <a href=\"${data.recordUrl}\" style=\"display: inline-block; padding: 12px 24px; background: #2563eb; color: white; text-decoration: none; border-radius: 6px;\">View Full Details</a>\n      </p>\n    `;\n    break;\n    \n  case 'submission_responded':\n    emailSubject = `Response to Submission: ${data.reference}`;\n    emailBody = `\n      <h2>Submission Response Ready</h2>\n      <p>We have reviewed your submission and our response is ready.</p>\n      <div style=\"background: #dbeafe; padding: 20px; border-left: 4px solid #2563eb; margin: 20px 0;\">\n        <h3>${data.reference}</h3>\n        <p><strong>Project:</strong> ${data.projectCode} - ${data.projectName}</p>\n        <p><strong>Original Subject:</strong> ${data.subject}</p>\n        <p><strong>Status:</strong> Responded</p>\n      </div>\n      <h3>Response Summary:</h3>\n      <p>${data.body.substring(0, 300)}...</p>\n      <p style=\"text-align: center; margin: 30px 0;\">\n        <a href=\"${ackUrl}\" style=\"display: inline-block; padding: 12px 24px; background: #10b981; color: white; text-decoration: none; border-radius: 6px;\">Acknowledge Receipt</a>\n      </p>\n    `;\n    break;\n    \n  case 'meeting_published':\n    emailSubject = `Meeting Minutes: ${data.subject}`;\n    emailBody = `\n      <h2>Meeting Minutes Available</h2>\n      <p>Minutes from our recent meeting are now available for your review.</p>\n      <div style=\"background: #dbeafe; padding: 20px; border-left: 4px solid #2563eb; margin: 20px 0;\">\n        <h3>${data.reference || data.subject}</h3>\n        <p><strong>Project:</strong> ${data.projectCode} - ${data.projectName}</p>\n        <p><strong>Meeting:</strong> ${data.subject}</p>\n      </div>\n      <p style=\"text-align: center; margin: 30px 0;\">\n        <a href=\"${data.recordUrl}\" style=\"display: inline-block; padding: 12px 24px; background: #2563eb; color: white; text-decoration: none; border-radius: 6px;\">View Minutes</a>\n      </p>\n    `;\n    break;\n    \n  default:\n    emailSubject = `Project Update: ${data.reference}`;\n    emailBody = `<p>A project update is available. Please check your project portal.</p>`;\n}\n\nconst fullEmailHtml = `\n<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; margin: 0; padding: 0; }\n    .container { max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { background: #2563eb; color: white; padding: 30px; text-align: center; border-radius: 8px 8px 0 0; }\n    .content { padding: 30px; background: #f9fafb; border: 1px solid #e5e7eb; border-top: none; }\n    .footer { padding: 20px; text-align: center; font-size: 12px; color: #666; background: #f3f4f6; border-radius: 0 0 8px 8px; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>True Build</h1>\n      <p style=\"margin: 10px 0 0 0; opacity: 0.9;\">Project Communication</p>\n    </div>\n    <div class=\"content\">\n      <p>Dear ${contactName},</p>\n      ${emailBody}\n      <p>If you have any questions, please don't hesitate to contact your project manager.</p>\n    </div>\n    <div class=\"footer\">\n      <p>True Build | Architecture & Project Management</p>\n      <p>This is an automated notification. Please do not reply directly to this email.</p>\n    </div>\n  </div>\n</body>\n</html>\n`;\n\nreturn {\n  json: {\n    ...data,\n    contactEmail,\n    contactName,\n    emailSubject,\n    emailHtml: fullEmailHtml,\n    ackToken,\n    ackUrl\n  }\n};"
