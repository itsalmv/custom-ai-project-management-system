      "parameters": {
        "jsCode": "const record = $input.first().json;\n\nconst recordType = $input.first().json['Record Type'];\nconst status = $input.first().json.Status\nconst toPartyType =$input.first().json['To party Type']\nconst fromPartyType = $input.first().json['From Party'];\n\n// Define notification triggers\nconst shouldNotify = \n  (recordType == 'VO' && status == 'Issued' && toPartyType == 'Client') ||\n  (recordType === 'Client Decision' && status === 'Published') ||\n  (recordType === 'Submission Log' && status === 'Responded' && fromPartyType === 'Vendor') ||\n  (recordType === 'Meeting Note' && status === 'Published');\n\nif (!shouldNotify) {\n  return {json: {skip: true, reason: 'No notification needed'}};\n}\n\nconst reference = $input.first().json.Reference;\nconst subject = $input.first().json.Subject;\nconst body =$input.first().json.Summary|| '';\nconst issueDate = $input.first().json['Issue Date'];\nconst toPartyId = $input.first().json['Email Contractor'];\nconst fromPartyId = $input.first().json['Last edited by'];\nconst projectId = $input.first().json.Reference.split('-')[0];\n\nconst recipientId = toPartyType === 'Client' ? toPartyId : fromPartyId;\n\nif (!recipientId || !projectId) {\n  return {json: {skip: true, reason: 'Missing required relations'}};\n}\n\nreturn {\n  json: {\n    recordId: record.id,\n    recordUrl: record.url,\n    recordType,\n    status,\n    reference,\n    subject,\n    body,\n    issueDate,\n    recipientId,\n    recipientType: toPartyType === 'Client' ? 'Client' : 'Vendor',\n    projectId,\n    notificationType: \n      recordType === 'VO' ? 'vo_issued' :\n      recordType === 'Client Decision' ? 'decision_published' :\n      recordType === 'Meeting Note' ? 'meeting_published' : 'other',\n    skip: false\n  }\n};"
      },
